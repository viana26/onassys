{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "clean": "node -e \"fs.rmSync('dist',{recursive:1,force:1})\"",
    "db:migrate": "node aplicar_migrations.mjs",
    "db:reset": "node supabase/reset-data.mjs",
    "db:clear": "node supabase/clear-movements.mjs",
    "db:seed:test": "node run-seed.mjs seed_test.sql",
    "db:seed:dashboard": "node run-seed.mjs seed_simulacao_dashboard.sql",
    "db:seed:cleanup": "node run-seed.mjs seed_cleanup.sql",
    "db:del": "node run-seed.mjs del_db.sql"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "chart.js": "^4.5.1",
    "dotenv": "^17.2.3",
    "driver.js": "^1.6.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
