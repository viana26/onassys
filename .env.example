# ==============================================================================
# CONFIGURAÇÕES DO SUPABASE (Obrigatórias para a aplicação Web/Frontend)
# Usadas tanto localmente quanto na Vercel/Netlify/GitHub Pages.
# ==============================================================================
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_ANON_KEY="sua-chave-anon-publica"
VITE_SUPABASE_SERVICE_ROLE_KEY="sua-chave-service-role-privada"

# (Opcional) Nome do bucket no Supabase Storage. Se omitido, usa 'imagem_produto' por padrão.
VITE_SUPABASE_BUCKET="imagem_produto"

# ==============================================================================
# STRINGS DE CONEXÃO DIRETA POSTGRESQL (Apenas para Scripts Locais / Migrations)
# Usada APENAS localmente por scripts Node.js (ex: npm run db:migrate).
# NÃO é necessária e NÃO é exposta na Vercel / Netlify / Frontend em Produção.
# ==============================================================================
DATABASE_URL="postgresql://postgres.[REF]:[SENHA]@aws-1-[REGIAO].pooler.supabase.com:5432/postgres"